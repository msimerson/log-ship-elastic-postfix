{
  "name": "log-ship-elastic-postfix",
  "description": "Ship normalized Postfix logs to Elasticsearch",
  "version": "1.0.0",
  "private": false,
  "keywords": [
    "log",
    "postfix",
    "elasticsearch",
    "log ship"
  ],
  "files": [
    "Changes.md",
    "index-map-template.json",
    "lib",
    "server.js",
    "log-ship-elastic-postfix.ini"
  ],
  "homepage": "https://github.com/msimerson/log-ship-elastic-postfix",
  "bugs": {
    "url": "https://github.com/msimerson/log-ship-elastic-postfix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/msimerson/log-ship-elastic-postfix.git"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "ini": "^6.0.0",
    "postfix-parser": "^1.1.2",
    "redis": "^5.12.1",
    "safe-log-reader": "^1.0.8"
  },
  "devDependencies": {},
  "license": "BSD-2-Clause",
  "scripts": {
    "lint": "npm install @eslint/js eslint globals && npx eslint .",
    "start": "node server.js",
    "test": "node test-runner.js",
    "test:coverage": "NODE_ENV=test node --test --experimental-test-coverage",
    "test:coverage:lcov": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update"
  }
}
